# ============================================================
# NexusSearch - Backend Environment Variables
# Copy this to .env and fill in your API keys
# ============================================================

# --- App ---
SECRET_KEY=your-super-secret-key-change-this
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173

# --- Database ---
DATABASE_URL=postgresql+asyncpg://nexus:nexus_secret@db:5432/nexussearch

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Legal OSINT API Keys ---

# Google Custom Search API
# Get it at: https://console.developers.google.com/
# Create a Custom Search Engine at: https://cse.google.com/
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# Hunter.io - Email intelligence (legal, paid service)
# Get it at: https://hunter.io/api
HUNTER_API_KEY=your_hunter_api_key_here

# Shodan - Device intelligence (legal)
# Get it at: https://account.shodan.io/
SHODAN_API_KEY=your_shodan_api_key_here

# HaveIBeenPwned - Breach checking (legal, requires license for full use)
# Get it at: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=your_hibp_api_key_here
